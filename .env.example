# ─────────────────────────────────────────────────────────────────
# LOOKING GLASS — Environment Configuration
# ─────────────────────────────────────────────────────────────────

# ── AI Provider Configuration ──────────────────────────────────────
# Default: Gemini Web2API (local proxy — run `bash scripts/start-gemini-proxy.sh`)
LLM_BASE_URL=http://localhost:8081/v1
LLM_API_KEY=gemini-web2api
LLM_MODEL=gemini-3.5-flash

# OpenRouter Fallback (optional — only needed if gemini-web2api is unreachable)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_FALLBACK_MODEL=openrouter/free

# ── Production (Cloudflare Tunnel) ───────────────────────────────
# When deployed, expose the local gemini-web2api via Cloudflare Tunnel:
#   cloudflared tunnel run <your-tunnel-name>
# Then set:
# LLM_BASE_URL=https://<your-tunnel>.trycloudflare.com/v1

# ── Optional Providers ────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ── Vercel / Deployment ──────────────────────────────────────────
# In Vercel dashboard, set these environment variables:
#   LLM_BASE_URL     → https://<your-tunnel>.trycloudflare.com/v1
#   OPENROUTER_API_KEY → sk-or-... (fallback)